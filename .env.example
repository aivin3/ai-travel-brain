# AI Travel Brain — 環境變數範例
# 本專案幾乎零 env：純 Python 標準庫 + 純前端 HTML，唔需要傳統 .env。
#
# 唯一「config」= firebase.config.json（client-side 公開值，可以 commit）。
# 只為「多人實時共用分帳」用；離線版唔需要。
#
# Firebase（Realtime Database）config 形狀（實際值見 firebase.config.json）：
# {
#   "apiKey": "AIza...",
#   "authDomain": "<project>.firebaseapp.com",
#   "databaseURL": "https://<project>-default-rtdb.<region>.firebasedatabase.app",   # 必須有，RTDB 用
#   "projectId": "<project>",
#   "storageBucket": "<project>.firebasestorage.app",
#   "messagingSenderId": "...",
#   "appId": "1:...:web:..."
# }
#
# GitHub 部署：用本機 git credential（keychain）已存嘅 Personal Access Token
#   （classic, scope=repo）。一次性用完建議去 GitHub 撤銷。
# GITHUB_TOKEN=ghp_xxx   # 唔建議寫入檔案；用 keychain / 即時貼
